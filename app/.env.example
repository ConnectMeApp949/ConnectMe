# ConnectMe App Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (required)
EXPO_PUBLIC_API_URL=https://api.connectmeapp.services

# Stripe (required for payments)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# Google Maps (required for location features)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# OAuth - Facebook (required for Facebook login)
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id

# OAuth - Google (required for Google login)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# OAuth - Apple (bundle ID used as client ID)
# Uses com.connectme.app from app.json by default
