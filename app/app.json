{
  "expo": {
    "name": "ConnectMe",
    "slug": "connectme",
    "owner": "connectme",
    "description": "ConnectMe is the premier marketplace for booking event vendors — DJs, caterers, photographers, food trucks, and more — in San Antonio and beyond.",
    "privacy": "public",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.connectmeapp.services",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ConnectMe uses your location to find vendors near you.",
        "NSPhotoLibraryUsageDescription": "ConnectMe needs access to your photos to upload profile and portfolio images.",
        "NSCameraUsageDescription": "ConnectMe needs camera access to take photos for your profile.",
        "NSPhotoLibraryAddUsageDescription": "ConnectMe needs access to save photos to your library",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.connectmeapp.services",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "scheme": "connectme",
    "plugins": [
      "expo-location",
      "expo-image-picker",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "privacyManifests": {
              "NSPrivacyAccessedAPITypes": [
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
                  "NSPrivacyAccessedAPITypeReasons": [
                    "CA92.1"
                  ]
                },
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
                  "NSPrivacyAccessedAPITypeReasons": [
                    "35F9.1"
                  ]
                },
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
                  "NSPrivacyAccessedAPITypeReasons": [
                    "E174.1"
                  ]
                }
              ]
            }
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "@stripe/stripe-react-native",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "d9312f5e-3b79-4266-950d-d9de8e507ed9"
      }
    }
  }
}
